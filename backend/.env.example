# ==========================================
# Amenity Booking Application - Backend Config
# ==========================================
# Copy this to .env in the backend/ folder
# Fill in actual values from your Supabase project
# DO NOT commit .env to Git (add to .gitignore)
# 
# Start FastAPI: uvicorn api_server:app --reload
# Health check: GET /health/live or /health/ready

# ==========================================
# REQUIRED - Supabase Configuration
# ==========================================
# Get these from: https://app.supabase.com/project/[your-project-id]/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# PostgreSQL connection string from Supabase
# Found in: https://app.supabase.com/project/[id]/settings/database
# Format: postgresql://postgres.[project]:password@[host]:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.[project]:password@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require

# ==========================================
# REQUIRED - API Security Keys
# ==========================================
# Generate strong random strings for these API keys
# Used in X-API-Key and X-Admin-API-Key headers
VOICE_BOOKING_API_KEY=generate-a-strong-random-key-here
ADMIN_API_KEY=generate-a-strong-random-key-here

# ==========================================
# REQUIRED - Sarvam AI Configuration
# ==========================================
# Get from: https://console.sarvam.ai/
SARVAM_API_KEY=sk_[your-sarvam-api-key]

# ==========================================
# OPTIONAL - CORS Origins
# ==========================================
# Comma-separated list of allowed frontend URLs
# Example: https://admin-amenity.netlify.app,https://user-amenity.netlify.app
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ==========================================
# OPTIONAL - Voice Booking Defaults
# ==========================================
# Used when building_id or user_id not provided to voice endpoints
VOICE_BOOKING_DEFAULT_BUILDING_ID=default-building-id
VOICE_BOOKING_DEFAULT_USER_ID=default-user-id

# ==========================================
# OPTIONAL - Render Deployment URL
# ==========================================
# Set this when deployed on Render
VOICE_BOOKING_API_BASE_URL=https://amenity-booking-api.onrender.com
```
